parse_ts <- function(raw, period_label) {
  raw$timeSeriesData %>%
    as_tibble() %>%
    filter(!is.na(date), date != "") %>%
    mutate(
      date   = as.Date(date),
      count  = as.numeric(count),
      period = period_label
    )
}

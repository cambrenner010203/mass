FIELD_ICD      <- "ddInformationText"
FIELD_FACILITY <- "facilityName"
FIELD_REGION   <- "NH_region"

# ── Signal status thresholds ──────────────────────────────────────────────────
# Tune these as the event progresses
THRESH_ELEVATED <- 20   # % change above prior year triggers ELEVATED
THRESH_ALERT    <- 50   # % change above prior year triggers ALERT

# ── Derived — do not edit ─────────────────────────────────────────────────────
YOY_START     <- REPORT_START - years(1)
YOY_END       <- REPORT_END   - years(1)
CHART_YOY     <- CHART_START  - years(1)

api_date <- function(d) format(as.Date(d), "%d%b%y")  # e.g. 01Jun26

report_label <- paste0(format(REPORT_START, "%B %d"),
                        " \u2013 ",
                        format(REPORT_END, "%B %d, %Y"))
yoy_label    <- paste0(format(YOY_START, "%B %d"),
                        " \u2013 ",
                        format(YOY_END, "%B %d, %Y"))
next_report  <- format(REPORT_END + days(7), "%B %d, %Y")

signal_status <- function(pct_change) {
  case_when(
    is.na(pct_change)              ~ "NORMAL",
    pct_change >= THRESH_ALERT    ~ "ALERT",
    pct_change >= THRESH_ELEVATED ~ "ELEVATED",
    TRUE                           ~ "NORMAL"
  )
}

set_flextable_defaults(font.family = "Verdana", font.size = 10)

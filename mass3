## 2. Syndromic Signals and Volume at a Glance

```{r signals_table}
# Color lookup
status_fill <- function(s) case_when(
  s == "ALERT"    ~ "FFB3B3",
  s == "ELEVATED" ~ "FFE699",
  TRUE            ~ "C6EFCE"
)
status_color <- function(s) case_when(
  s == "ALERT"    ~ "C00000",
  s == "ELEVATED" ~ "7F6000",
  TRUE            ~ "375623"
)

ft <- signals %>%
  select(syndrome, current, yoy, change_label, status) %>%
  rename(
    Signal              = syndrome,
    `This Year`         = current,
    `Prior Year`        = yoy,
    `% Change`          = change_label,
    Status              = status
  ) %>%
  flextable() %>%
  bold(part = "header") %>%
  bg(part = "header", bg = "#BDD7EE") %>%
  width(j = 1, width = 2.6) %>%
  width(j = 2, width = 1.0) %>%
  width(j = 3, width = 1.0) %>%
  width(j = 4, width = 1.0) %>%
  width(j = 5, width = 1.2) %>%
  align(j = 2:5, align = "center", part = "all") %>%
  bold(j = 5) %>%
  border_outer(part = "all", border = fp_border(color = "#BFBFBF", width = 1)) %>%
  border_inner(border = fp_border(color = "#BFBFBF", width = 0.5)) %>%
  set_caption("Syndromic signals and volume at a glance") %>%
  bg(i = seq(2, nrow(signals), 2), bg = "#DEEAF1")

# Apply status colors and flag elevated % change rows
for (i in seq_len(nrow(signals))) {
  ft <- ft %>%
    bg(i = i, j = 5, bg = paste0("#", status_fill(signals$status[i]))) %>%
    color(i = i, j = 5, color = paste0("#", status_color(signals$status[i])))

  if (!is.na(signals$pct_change[i]) && signals$pct_change[i] >= THRESH_ELEVATED) {
    ft <- ft %>%
      color(i = i, j = 4, color = "#C00000") %>%
      bold(i = i, j = 4)
  }
}

ft

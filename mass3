EVENT_NAME    <- "2026 FIFA World Cup"
EVENT_START   <- as.Date("2026-06-01")   # first day of event surveillance
EVENT_END     <- as.Date("2026-07-19")   # last day of event
REPORT_START  <- as.Date("2026-06-01")   # start of THIS report period
REPORT_END    <- min(as.Date("2026-06-07"), Sys.Date())  # end of THIS report period
ANALYST_NAME  <- "Jane Smith, MPH"
BUREAU        <- "Bureau of Epidemiology"
DISTRIBUTION  <- "Surveillance Unit, Health Officer, EOC"

# Chart always anchors one week before EVENT_START regardless of report week

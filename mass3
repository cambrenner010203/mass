```{r icd_functions, include=FALSE}
# ── ICD-10 classification via prefix matching on raw codes ────────────────────
# Codes narrowed to event-relevant presentations only
# Broad S/T traumatic injury range excluded; replaced with specific injury codes

classify_icd <- function(icd) {
  case_when(
    str_detect(icd, "^T67")                    ~ "Heat Illness (T67)",
    str_detect(icd, "^E86")                    ~ "Dehydration (E86)",
    str_detect(icd, "^F10|^T51")               ~ "Alcohol-Related (F10 / T51)",
    str_detect(icd, "^A09|^R11")               ~ "Food Poisoning / GI (A09 / R11)",
    str_detect(icd, "^T40")                    ~ "Drug Toxicity / Opioid (T40)",
    str_detect(icd, "^S0[1-9]|^S10|^S1[0-9]") ~ "Laceration / Open Wound (S01-S19)",
    str_detect(icd, "^S[2-9][0-9]|^S[1-9][0-9][0-9]") ~ "Fracture (S-series)",
    str_detect(icd, "^R55")                    ~ "Syncope / Collapse (R55)",
    str_detect(icd, "^I46")                    ~ "Cardiac Arrest (I46)",
    str_detect(icd, "^J06|^J11|^J12|^J18")    ~ "Respiratory / ILI (J06-J18)",
    str_detect(icd, "^F41")                    ~ "Panic / Anxiety (F41)",
    str_detect(icd, "^T78\\.2|^L50")           ~ "Anaphylaxis / Allergy",
    str_detect(icd, "^Y04|^T74")               ~ "Assault / Violence (Y04 / T74)",
    TRUE                                        ~ NA_character_
  )
}

parse_icd <- function(raw, period_label) {
  raw$dataDetails %>%
    as_tibble() %>%
    mutate(icd_split = str_split(.[[FIELD_ICD]], "\\|")) %>%
    unnest(icd_split) %>%
    mutate(
      icd_code = str_trim(icd_split),
      category = classify_icd(icd_code),
      period   = period_label
    ) %>%
    filter(!is.na(category))
}
```


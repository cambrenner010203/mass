```{r pull_timeseries, include=FALSE}
build_ts_url <- function(start, end) {
  glue(
    "{ESSENCE_BASE}/api/timeSeries",
    "?endDate={api_date(end)}",
    "&startDate={api_date(start)}",
    "&percentParam=noPercent",
    "&datasource={DATASOURCE}",
    "&smoothing=0",
    "&graphOnly=true",
    "&timeResolution=daily",
    "&hasBeenE=1",
    "&medicalGroupingSystem=essencesyndromes",
    "&aqtTarget=TimeSeries"
  )
}

parse_ts <- function(raw, period_label) {
  raw$timeSeriesData %>%
    as_tibble() %>%
    mutate(
      date   = as.Date(date, "%m/%d/%Y"),
      count  = as.numeric(count),
      period = period_label
    )
}

ts_current     <- get_api_data(build_ts_url(EVENT_START, REPORT_END), profile = myProfile) %>%
  parse_ts("This Year")

ts_yoy         <- get_api_data(build_ts_url(YOY_START, YOY_END), profile = myProfile) %>%
  parse_ts("Prior Year (YOY)")

# Shift YOY dates forward one year so both series share the same x-axis
ts_yoy_aligned <- ts_yoy %>% mutate(date = date + years(1))
ts_combined    <- bind_rows(ts_current, ts_yoy_aligned)

# Daily comparison table
ts_table <- ts_current %>%
  select(date, count) %>%
  rename(current = count) %>%
  left_join(
    ts_yoy_aligned %>% select(date, count) %>% rename(yoy = count),
    by = "date"
  ) %>%
  mutate(
    pct_change   = if_else(
      is.na(yoy) | yoy == 0, NA_real_,
      round((current - yoy) / yoy * 100, 1)
    ),
    change_label = case_when(
      is.na(pct_change) ~ "N/A",
      pct_change  > 0   ~ glue("+{pct_change}%"),
      TRUE              ~ glue("{pct_change}%")
    ),
    flag         = !is.na(pct_change) & pct_change > 20,
    date_label   = format(date, "%a %b %d")
  )
```

```{r pull_cc, include=FALSE}
build_cc_url <- function(start, end) {
  glue(
    "{ESSENCE_BASE}/api/dataDetails",
    "?endDate={api_date(end)}",
    "&startDate={api_date(start)}",
    "&datasource={DATASOURCE}",
    "&hasBeenE=1",
    "&medicalGroupingSystem=essencesyndromes",
    "&aqtTarget=DataDetails"
  )
}

classify_cc <- function(cc_text) {
  cc <- tolower(cc_text)
  case_when(
    str_detect(cc, "heat|hypertherm|overheated|heat exhaustion|heat stroke")        ~ "Heat Illness",
    str_detect(cc, "lacerat|fractur|fall|blunt|trauma|mvc|stab|gsw|assault|fight") ~ "Traumatic Injury",
    str_detect(cc, "intox|etoh|drunk|alcohol|passed out|altered")                  ~ "Alcohol / ETOH",
    str_detect(cc, "nausea|vomit|diarrhea|abdominal|abd pain|food poison|n/v")     ~ "Food Poisoning / GI",
    str_detect(cc, "overdose|ingestion|opioid|fentanyl|narcan|naloxone")           ~ "Drug Toxicity",
    str_detect(cc, "chest pain|chest pressure|palpitat|syncope|cardiac")           ~ "Cardiac",
    str_detect(cc, "fever|cough|shortness of breath|sob|flu|uri|respiratory")      ~ "Respiratory / ILI",
    str_detect(cc, "anxiety|panic|behavioral|agitat|psychiatric|suicid")           ~ "Mental Health",
    str_detect(cc, "crush|trampl|stampede|crowd")                                  ~ "Crowd Crush",
    TRUE                                                                            ~ "Other"
  )
}

parse_cc <- function(raw, period_label) {
  raw$dataDetails %>%
    as_tibble() %>%
    mutate(
      syndrome = classify_cc(.data[[FIELD_CC]]),
      period   = period_label
    )
}

cc_current <- get_api_data(build_cc_url(EVENT_START, REPORT_END), profile = myProfile) %>%
  parse_cc("This Year")

cc_yoy <- get_api_data(build_cc_url(YOY_START, YOY_END), profile = myProfile) %>%
  parse_cc("Prior Year (YOY)")

cc_summary <- bind_rows(cc_current, cc_yoy) %>%
  count(syndrome, period) %>%
  pivot_wider(names_from = period, values_from = n, values_fill = 0) %>%
  rename(current = `This Year`, yoy = `Prior Year (YOY)`) %>%
  mutate(
    pct_change   = if_else(yoy == 0, NA_real_, round((current - yoy) / yoy * 100, 1)),
    change_label = case_when(
      is.na(pct_change) ~ "N/A",
      pct_change  > 0   ~ glue("+{pct_change}%"),
      TRUE              ~ glue("{pct_change}%")
    )
  ) %>%
  arrange(desc(current))

# Derive facility list from live data — no hardcoding
facility_list <- cc_current %>%
  distinct(.data[[FIELD_FACILITY]]) %>%
  arrange(.data[[FIELD_FACILITY]]) %>%
  pull(1) %>%
  paste(collapse = ", ")
```

```{r pull_icd, include=FALSE}
build_icd_url <- function(start, end) {
  glue(
    "{ESSENCE_BASE}/api/dataDetails",
    "?endDate={api_date(end)}",
    "&startDate={api_date(start)}",
    "&datasource={DATASOURCE}",
    "&hasBeenE=1",
    "&ddAvailable=1",
    "&aqtTarget=DataDetails"
  )
}

classify_icd <- function(icd) {
  case_when(
    str_detect(icd, "^T67")            ~ "Heat Illness (T67)",
    str_detect(icd, "^E86")            ~ "Dehydration (E86)",
    str_detect(icd, "^W52")            ~ "Crowd Crush (W52)",
    str_detect(icd, "^T40")            ~ "Drug Toxicity / Opioid (T40)",
    str_detect(icd, "^F10|^T51")       ~ "Alcohol-Related (F10 / T51)",
    str_detect(icd, "^A09|^R11")       ~ "Food Poisoning / GI (A09 / R11)",
    str_detect(icd, "^I46")            ~ "Cardiac Arrest (I46)",
    str_detect(icd, "^R55")            ~ "Syncope / Collapse (R55)",
    str_detect(icd, "^J06|^J11|^J18")  ~ "Respiratory / ILI (J06-J18)",
    str_detect(icd, "^F41")            ~ "Panic / Anxiety (F41)",
    str_detect(icd, "^T78\\.2|^L50")   ~ "Anaphylaxis / Allergy",
    str_detect(icd, "^S|^T1[0-4]")     ~ "Traumatic Injury (S / T)",
    str_detect(icd, "^Y04|^T74")       ~ "Assault / Violence (Y04 / T74)",
    TRUE                               ~ NA_character_
  )
}

parse_icd <- function(raw, period_label) {
  raw$dataDetails %>%
    as_tibble() %>%
    mutate(icd_raw = str_split(.data[[FIELD_ICD]], "\\|")) %>%
    unnest(icd_raw) %>%
    mutate(
      icd_code = str_trim(icd_raw),
      category = classify_icd(icd_code),
      period   = period_label
    ) %>%
    filter(!is.na(category))
}

icd_current <- get_api_data(build_icd_url(EVENT_START, REPORT_END), profile = myProfile) %>%
  parse_icd("This Year")

icd_yoy <- get_api_data(build_icd_url(YOY_START, YOY_END), profile = myProfile) %>%
  parse_icd("Prior Year (YOY)")

icd_summary <- bind_rows(icd_current, icd_yoy) %>%
  count(category, period) %>%
  pivot_wider(names_from = period, values_from = n, values_fill = 0) %>%
  rename(current = `This Year`, yoy = `Prior Year (YOY)`) %>%
  mutate(
    pct_change   = if_else(yoy == 0, NA_real_, round((current - yoy) / yoy * 100, 1)),
    change_label = case_when(
      is.na(pct_change) ~ "N/A",
      pct_change  > 0   ~ glue("+{pct_change}%"),
      TRUE              ~ glue("{pct_change}%")
    )
  ) %>%
  arrange(desc(current))
```

```{r data_quality, include=FALSE}
# CC completeness — derived from the live pull, no manual entry
cc_quality <- cc_current %>%
  group_by(facility = .data[[FIELD_FACILITY]]) %>%
  summarise(
    total_visits    = n(),
    cc_present      = sum(!is.na(.data[[FIELD_CC]]) & .data[[FIELD_CC]] != ""),
    cc_completeness = round(cc_present / total_visits * 100, 1),
    .groups         = "drop"
  )

# ICD-10 lag — derived from difference between visit date and DD date
icd_quality <- icd_current %>%
  mutate(
    visit_dt = as.Date(.data[[FIELD_VISIT_DATE]], "%m/%d/%Y"),
    dd_dt    = as.Date(.data[[FIELD_DD_DATE]],    "%m/%d/%Y"),
    lag_hrs  = as.numeric(difftime(dd_dt, visit_dt, units = "hours"))
  ) %>%
  group_by(facility = .data[[FIELD_FACILITY]]) %>%
  summarise(
    avg_lag_hrs = round(mean(lag_hrs, na.rm = TRUE), 1),
    .groups     = "drop"
  )

data_quality <- cc_quality %>%
  left_join(icd_quality, by = "facility") %>%
  mutate(
    lag_display = if_else(is.na(avg_lag_hrs), "No ICD data yet", as.character(avg_lag_hrs))
  )

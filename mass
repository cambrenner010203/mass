library(Rnssp)
library(tidyverse)
library(flextable)
library(officer)
library(officedown)
library(lubridate)
library(scales)
library(glue)

# ── Resolve params ────────────────────────────────────────────────────────────
EVENT_NAME    <- params$event_name
EVENT_START   <- as.Date(params$event_start)
EVENT_END     <- as.Date(params$event_end)
ESSENCE_BASE  <- params$essence_base
DATASOURCE    <- params$datasource

FIELD_CC          <- params$field_cc
FIELD_ICD         <- params$field_icd
FIELD_DD_DATE     <- params$field_dd_date
FIELD_VISIT_DATE  <- params$field_visit_date
FIELD_FACILITY    <- params$field_facility

# ── Derived dates ─────────────────────────────────────────────────────────────
REPORT_END  <- min(EVENT_END, Sys.Date())   # never requests future data
YOY_START   <- EVENT_START - years(1)
YOY_END     <- REPORT_END  - years(1)

api_date <- function(d) format(as.Date(d), "%d%b%Y")

report_label <- glue(
  "{format(EVENT_START, '%B %d')} \u2013 {format(REPORT_END, '%B %d, %Y')}"
)
yoy_label <- glue(
  "{format(YOY_START, '%B %d')} \u2013 {format(YOY_END, '%B %d, %Y')}"
)
next_report_date <- format(REPORT_END + days(7), "%B %d, %Y")

# ── flextable defaults ────────────────────────────────────────────────────────
set_flextable_defaults(font.family = "Arial", font.size = 10)

## 1. ED Visit Volume

```{r ts_plot, fig.cap="Daily ED visit counts — current event period vs. same dates one year ago."}
ggplot(ts_combined, aes(x = date, y = count, color = period, linetype = period)) +
  geom_line(linewidth = 0.9) +
  geom_point(size = 2) +
  scale_color_manual(
    values = c("This Year" = "#1F4E79", "Prior Year (YOY)" = "#ED7D31")
  ) +
  scale_linetype_manual(
    values = c("This Year" = "solid", "Prior Year (YOY)" = "dashed")
  ) +
  scale_x_date(date_labels = "%b %d", date_breaks = "1 day") +
  scale_y_continuous(labels = comma, limits = c(0, NA)) +
  labs(
    title    = glue("Daily ED Visits \u2014 {EVENT_NAME}"),
    subtitle = glue("Current: {report_label}  |  YOY: {yoy_label}"),
    x = NULL, y = "ED Visits", color = NULL, linetype = NULL
  ) +
  theme_minimal(base_family = "Arial", base_size = 10) +
  theme(
    axis.text.x      = element_text(angle = 45, hjust = 1),
    panel.grid.minor = element_blank(),
    legend.position  = "bottom"
  )
```

